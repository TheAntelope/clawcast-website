# Copy this file to .env.local and fill in real values for local dev.
# All names that end up in the browser must be prefixed with NEXT_PUBLIC_;
# everything below is server-only.

# ElevenLabs Instant Voice Cloning. Without it, /creators/start/voice falls
# back to a placeholder voice ID so the wizard remains testable.
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
